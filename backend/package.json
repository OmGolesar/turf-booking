{
  "name": "turfx-backend",
  "version": "0.1.0",
  "private": true,
  "description": "TurfX backend — Nashik MVP",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "start:worker": "ts-node -r tsconfig-paths/register src/worker.main.ts",
    "start:worker:dev": "nest start --watch --entryFile worker.main",
    "start:worker:prod": "node dist/worker.main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:reset": "prisma migrate reset --force",
    "db:seed": "ts-node prisma/seed.ts",
    "test": "jest",
    "test:unit": "jest",
    "test:cov": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.10",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.19.1",
    "@supabase/supabase-js": "^2.110.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cron-parser": "^4.9.0",
    "firebase-admin": "^14.1.0",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "razorpay": "^2.9.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ulid": "^3.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.22",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.10",
    "jest": "^29.7.0",
    "prisma": "^5.19.1",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
