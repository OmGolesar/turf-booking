// TurfX schema — Nashik MVP.
// Definitive spec: Implementation plan/PART_2_5_DATABASE_DESIGN/part_2.5.2_CONSOLIDATED_SCHEMA.md
// Platform tables: part_2.5.3.md
// Migration order defined in part_2.5.3.md §5. All raw SQL lives under prisma/migrations/*.
//
// Audit trio (created_by, updated_by, deleted_by, deleted_at) is present as scalar
// UUID columns on every business table except payments, reviews, audit_logs, outbox_events.
// FK constraints for those columns are added in migration SQL, not modelled here.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, postgis, uuid_ossp(map: "uuid-ossp")]
}

// ─── Enums ────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  PARTNER
  MANAGER
  STAFF
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
  DELETED
}

enum PartnerStatus {
  PENDING
  UNDER_REVIEW
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum VenueStatus {
  DRAFT
  UNDER_REVIEW
  PUBLISHED
  SUSPENDED
  ARCHIVED
}

enum GroundStatus {
  DRAFT
  ACTIVE
  MAINTENANCE
  BLOCKED
  ARCHIVED
}

enum SurfaceType {
  NATURAL_GRASS
  ARTIFICIAL_TURF
  SYNTHETIC
  CLAY
  WOOD
  RUBBER
  CONCRETE
}

enum MediaType {
  COVER
  GALLERY
  LOGO
}

enum BookingSessionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum BookingSource {
  CUSTOMER_APP
  PARTNER_APP
  WALK_IN
  PHONE
  WHATSAPP
  ADMIN
}

enum BookingStatus {
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  REFUNDED
  NO_SHOW
}

enum PaymentProvider {
  RAZORPAY
  OFFLINE
}

enum PaymentMethod {
  UPI
  CARD
  NETBANKING
  CASH
  WALLET
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
}

enum NotificationChannel {
  PUSH
  SMS
  EMAIL
  WHATSAPP
  IN_APP
}

enum NotificationCategory {
  BOOKING_CONFIRMATION
  BOOKING_REMINDER
  BOOKING_CANCELLATION
  PAYMENT_SUCCESS
  PAYMENT_FAILURE
  REFUND_PROCESSED
  CHECK_IN_REMINDER
  REVIEW_REQUEST
  VENUE_APPROVED
  VENUE_SUSPENDED
  GROUND_MAINTENANCE
  PROMOTION
  SYSTEM_ANNOUNCEMENT
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum DevicePlatform {
  ANDROID
  IOS
  WEB
}

enum AppVariant {
  CUSTOMER
  PARTNER
  ADMIN
}

enum AppSettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
  SECRET
}

enum BackgroundJobType {
  SCHEDULED
  ONE_SHOT
}

enum BackgroundJobStatus {
  IDLE
  RUNNING
  SUCCESS
  FAILED
  DISABLED
}

// ─── Reference: Sports ────────────────────────────────────────────────────

model Sport {
  id                     String   @id @default(uuid()) @db.Uuid
  code                   String   @unique @db.VarChar(32)
  displayName            String   @map("display_name") @db.VarChar(64)
  iconUrl                String?  @map("icon_url")
  defaultDurationMinutes Int      @default(60) @map("default_duration_minutes")
  defaultMaxPlayers      Int      @default(10) @map("default_max_players")
  displayOrder           Int      @default(0) @map("display_order")
  isActive               Boolean  @default(true) @map("is_active")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  grounds Ground[]

  @@index([isActive, displayOrder])
  @@map("sports")
}

// ─── Identity & Partner ───────────────────────────────────────────────────

model Identity {
  id            String     @id @default(uuid()) @db.Uuid
  referenceCode String?    @unique @map("reference_code") @db.VarChar(32)
  firebaseUid   String     @unique @map("firebase_uid")
  email         String?    @unique
  phone         String?    @unique
  role            Role
  status          UserStatus @default(ACTIVE)
  lastLoginAt     DateTime?  @map("last_login_at") @db.Timestamptz(6)
  phoneVerifiedAt DateTime?  @map("phone_verified_at") @db.Timestamptz(6)
  emailVerifiedAt DateTime?  @map("email_verified_at") @db.Timestamptz(6)
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  profile         IdentityProfile?
  partner         Partner?
  bookingSessions BookingSession[]
  bookings        Booking[]
  reviews         Review[]
  deviceTokens    DeviceToken[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  favourites      CustomerFavourite[]

  @@index([role, status])
  @@map("identities")
}

model IdentityProfile {
  id         String    @id @default(uuid()) @db.Uuid
  identityId String    @unique @map("identity_id") @db.Uuid
  firstName  String    @map("first_name")
  lastName   String?   @map("last_name")
  avatarUrl  String?   @map("avatar_url")
  city       String?
  state      String?
  country    String?   @default("India")
  language   String?   @default("en")
  timezone   String?   @default("Asia/Kolkata")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  identity Identity @relation(fields: [identityId], references: [id])

  @@map("identity_profiles")
}

model Partner {
  id            String        @id @default(uuid()) @db.Uuid
  referenceCode String        @unique @default("") @map("reference_code") @db.VarChar(32)
  identityId    String        @unique @map("identity_id") @db.Uuid
  businessName  String        @map("business_name")
  displayName   String        @map("display_name")
  email         String?
  phone         String
  address       String?
  city          String        @default("Nashik")
  state         String        @default("Maharashtra")
  status        PartnerStatus @default(PENDING)
  isVerified    Boolean       @default(false) @map("is_verified")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  identity Identity     @relation(fields: [identityId], references: [id])
  venues   Venue[]
  settings AppSetting[]
  bookings Booking[]

  @@index([city, status])
  @@index([status, isVerified])
  @@map("partners")
}

// ─── Venue & Ground ───────────────────────────────────────────────────────

model Venue {
  id            String      @id @default(uuid()) @db.Uuid
  referenceCode String      @unique @default("") @map("reference_code") @db.VarChar(32)
  partnerId     String      @map("partner_id") @db.Uuid
  name          String
  slug          String      @unique
  description   String?
  phone         String?
  email         String?
  address       String
  area          String?
  city          String      @default("Nashik")
  state         String      @default("Maharashtra")
  postalCode    String?     @map("postal_code")
  latitude      Decimal     @db.Decimal(10, 8)
  longitude     Decimal     @db.Decimal(11, 8)
  // location geography(Point,4326) is added in migration 0004 via raw SQL
  googleMapsUrl String?     @map("google_maps_url")
  amenities     Json?
  averageRating Float       @default(0) @map("average_rating")
  totalReviews  Int         @default(0) @map("total_reviews")
  status        VenueStatus @default(DRAFT)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  partner    Partner             @relation(fields: [partnerId], references: [id])
  grounds    Ground[]
  media      VenueMedia[]
  reviews    Review[]
  bookings   Booking[]
  favourites CustomerFavourite[]

  @@index([partnerId])
  @@index([city, status])
  @@index([status])
  @@index([averageRating(sort: Desc)])
  @@map("venues")
}

model VenueMedia {
  id           String    @id @default(uuid()) @db.Uuid
  venueId      String    @map("venue_id") @db.Uuid
  fileUrl      String    @map("file_url")
  mediaType    MediaType @map("media_type")
  displayOrder Int       @default(0) @map("display_order")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  venue Venue @relation(fields: [venueId], references: [id])

  @@index([venueId, displayOrder])
  @@map("venue_media")
}

model Ground {
  id            String       @id @default(uuid()) @db.Uuid
  referenceCode String       @unique @default("") @map("reference_code") @db.VarChar(32)
  venueId       String       @map("venue_id") @db.Uuid
  sportId       String       @map("sport_id") @db.Uuid
  name          String
  surfaceType   SurfaceType  @map("surface_type")
  indoor        Boolean      @default(false)
  maxPlayers    Int          @map("max_players")
  lighting      Boolean      @default(true)
  description   String?
  status        GroundStatus @default(DRAFT)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  venue          Venue                   @relation(fields: [venueId], references: [id])
  sport          Sport                   @relation(fields: [sportId], references: [id])
  configuration  GroundConfiguration?
  media          GroundMedia[]
  operatingHours OperatingHour[]
  exceptions     AvailabilityException[]
  maintenance    MaintenanceBlock[]
  pricingRules   PricingRule[]
  sessions       BookingSession[]
  bookings       Booking[]

  @@index([venueId, status])
  @@index([sportId])
  @@index([status])
  @@map("grounds")
}

model GroundMedia {
  id           String   @id @default(uuid()) @db.Uuid
  groundId     String   @map("ground_id") @db.Uuid
  fileUrl      String   @map("file_url")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  ground Ground @relation(fields: [groundId], references: [id])

  @@index([groundId, displayOrder])
  @@map("ground_media")
}

model GroundConfiguration {
  id                      String   @id @default(uuid()) @db.Uuid
  groundId                String   @unique @map("ground_id") @db.Uuid
  bookingDuration         Int      @map("booking_duration")
  bookingInterval         Int      @map("booking_interval")
  bufferTime              Int      @default(0) @map("buffer_time")
  cleaningTime            Int      @default(0) @map("cleaning_time")
  maxAdvanceBookingDays   Int      @default(30) @map("max_advance_booking_days")
  minNoticeMinutes        Int      @default(30) @map("min_notice_minutes")
  cancellationWindowHours Int      @default(4) @map("cancellation_window_hours")
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  ground Ground @relation(fields: [groundId], references: [id])

  @@map("ground_configurations")
}

// ─── Scheduling ───────────────────────────────────────────────────────────

model OperatingHour {
  id          String   @id @default(uuid()) @db.Uuid
  groundId    String   @map("ground_id") @db.Uuid
  dayOfWeek   Int      @map("day_of_week")
  openingTime DateTime @map("opening_time") @db.Time(6)
  closingTime DateTime @map("closing_time") @db.Time(6)
  isClosed    Boolean  @default(false) @map("is_closed")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  ground Ground @relation(fields: [groundId], references: [id])

  @@unique([groundId, dayOfWeek])
  @@index([groundId])
  @@map("operating_hours")
}

model AvailabilityException {
  id            String   @id @default(uuid()) @db.Uuid
  groundId      String   @map("ground_id") @db.Uuid
  title         String
  exceptionDate DateTime @map("exception_date") @db.Date
  startTime     DateTime @map("start_time") @db.Time(6)
  endTime       DateTime @map("end_time") @db.Time(6)
  isClosed      Boolean  @default(true) @map("is_closed")
  reason        String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  ground Ground @relation(fields: [groundId], references: [id])

  @@index([groundId, exceptionDate])
  @@index([exceptionDate])
  @@map("availability_exceptions")
}

model MaintenanceBlock {
  id            String   @id @default(uuid()) @db.Uuid
  groundId      String   @map("ground_id") @db.Uuid
  title         String
  startDatetime DateTime @map("start_datetime") @db.Timestamptz(6)
  endDatetime   DateTime @map("end_datetime") @db.Timestamptz(6)
  description   String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  ground Ground @relation(fields: [groundId], references: [id])

  @@index([groundId, startDatetime])
  @@index([startDatetime, endDatetime])
  @@map("maintenance_blocks")
}

model PricingRule {
  id            String    @id @default(uuid()) @db.Uuid
  groundId      String    @map("ground_id") @db.Uuid
  name          String
  dayOfWeek     Int?      @map("day_of_week")
  startTime     DateTime  @map("start_time") @db.Time(6)
  endTime       DateTime  @map("end_time") @db.Time(6)
  pricePerSlot  Decimal   @map("price_per_slot") @db.Decimal(10, 2)
  priority      Int
  active        Boolean   @default(true)
  effectiveFrom DateTime? @map("effective_from") @db.Timestamptz(6)
  effectiveTo   DateTime? @map("effective_to") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  ground Ground @relation(fields: [groundId], references: [id])

  @@unique([groundId, priority])
  @@index([groundId, active])
  @@index([groundId, dayOfWeek, active])
  @@map("pricing_rules")
}

// ─── Booking ──────────────────────────────────────────────────────────────

model BookingSession {
  id          String               @id @default(uuid()) @db.Uuid
  identityId  String               @map("identity_id") @db.Uuid
  groundId    String               @map("ground_id") @db.Uuid
  bookingDate DateTime             @map("booking_date") @db.Date
  startTime   DateTime             @map("start_time") @db.Time(6)
  endTime     DateTime             @map("end_time") @db.Time(6)
  totalAmount Decimal              @map("total_amount") @db.Decimal(10, 2)
  expiresAt   DateTime             @map("expires_at") @db.Timestamptz(6)
  status      BookingSessionStatus @default(ACTIVE)
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  identity Identity @relation(fields: [identityId], references: [id])
  ground   Ground   @relation(fields: [groundId], references: [id])
  booking  Booking?

  @@index([identityId])
  @@index([groundId, bookingDate])
  @@index([status, expiresAt])
  @@map("booking_sessions")
}

model Booking {
  id                 String        @id @default(uuid()) @db.Uuid
  referenceCode      String        @unique @default("") @map("reference_code") @db.VarChar(32)
  bookingSessionId   String        @unique @map("booking_session_id") @db.Uuid
  identityId         String        @map("identity_id") @db.Uuid
  partnerId          String        @map("partner_id") @db.Uuid
  venueId            String        @map("venue_id") @db.Uuid
  groundId           String        @map("ground_id") @db.Uuid
  bookingDate        DateTime      @map("booking_date") @db.Date
  startTime          DateTime      @map("start_time") @db.Time(6)
  endTime            DateTime      @map("end_time") @db.Time(6)
  bookingSource      BookingSource @map("booking_source")
  bookingStatus      BookingStatus @default(CONFIRMED) @map("booking_status")
  totalAmount        Decimal       @map("total_amount") @db.Decimal(10, 2)
  currency           String        @default("INR")
  checkedInAt        DateTime?     @map("checked_in_at") @db.Timestamptz(6)
  completedAt        DateTime?     @map("completed_at") @db.Timestamptz(6)
  cancelledAt        DateTime?     @map("cancelled_at") @db.Timestamptz(6)
  cancellationReason String?       @map("cancellation_reason")
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  session  BookingSession @relation(fields: [bookingSessionId], references: [id])
  identity Identity       @relation(fields: [identityId], references: [id])
  partner  Partner        @relation(fields: [partnerId], references: [id])
  venue    Venue          @relation(fields: [venueId], references: [id])
  ground   Ground         @relation(fields: [groundId], references: [id])
  payment  Payment?
  review   Review?

  @@index([identityId, createdAt(sort: Desc)])
  @@index([groundId, bookingDate])
  @@index([partnerId, bookingDate])
  @@index([venueId, bookingDate])
  @@index([bookingStatus, bookingDate])
  @@index([referenceCode])
  @@map("bookings")
}

// payments — no audit trio, no deletedAt (immutable transactional record)
model Payment {
  id                   String          @id @default(uuid()) @db.Uuid
  referenceCode        String          @unique @default("") @map("reference_code") @db.VarChar(32)
  bookingId            String          @unique @map("booking_id") @db.Uuid
  paymentProvider      PaymentProvider @map("payment_provider")
  transactionReference String          @unique @map("transaction_reference")
  amount               Decimal         @db.Decimal(10, 2)
  currency             String          @default("INR")
  paymentMethod        PaymentMethod   @map("payment_method")
  paymentStatus        PaymentStatus   @default(PENDING) @map("payment_status")
  paidAt               DateTime?       @map("paid_at") @db.Timestamptz(6)
  refundedAt           DateTime?       @map("refunded_at") @db.Timestamptz(6)
  refundAmount         Decimal?        @map("refund_amount") @db.Decimal(10, 2)
  refundReason         String?         @map("refund_reason")
  providerPayload      Json?           @map("provider_payload")
  createdAt            DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([paymentStatus])
  @@index([paymentProvider, paymentStatus])
  @@map("payments")
}

// reviews — no audit trio, no updatedAt (immutable customer content)
model Review {
  id         String   @id @default(uuid()) @db.Uuid
  bookingId  String   @unique @map("booking_id") @db.Uuid
  venueId    String   @map("venue_id") @db.Uuid
  identityId String   @map("identity_id") @db.Uuid
  rating     Int
  reviewText String?  @map("review_text")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  booking  Booking  @relation(fields: [bookingId], references: [id])
  venue    Venue    @relation(fields: [venueId], references: [id])
  identity Identity @relation(fields: [identityId], references: [id])

  @@index([venueId, createdAt(sort: Desc)])
  @@index([identityId])
  @@map("reviews")
}

// ─── Platform ─────────────────────────────────────────────────────────────

model ReferenceCodeSequence {
  id         String   @id @default(uuid()) @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(16)
  year       Int
  lastValue  BigInt   @default(0) @map("last_value")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([entityType, year])
  @@map("reference_code_sequences")
}

model AuditLog {
  id                    String   @id @default(uuid()) @db.Uuid
  actorIdentityId       String?  @map("actor_identity_id") @db.Uuid
  actorRole             String   @map("actor_role") @db.VarChar(16)
  action                String   @db.VarChar(64)
  resourceType          String   @map("resource_type") @db.VarChar(32)
  resourceId            String   @map("resource_id") @db.Uuid
  resourceReferenceCode String?  @map("resource_reference_code") @db.VarChar(32)
  changes               Json?
  context               Json?
  occurredAt            DateTime @map("occurred_at") @db.Timestamptz(6)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actor Identity? @relation(fields: [actorIdentityId], references: [id])

  @@index([resourceType, resourceId, occurredAt(sort: Desc)])
  @@index([actorIdentityId, occurredAt(sort: Desc)])
  @@index([action, occurredAt(sort: Desc)])
  @@map("audit_logs")
}

model OutboxEvent {
  id             String       @id @default(uuid()) @db.Uuid
  aggregateType  String       @map("aggregate_type") @db.VarChar(32)
  aggregateId    String       @map("aggregate_id") @db.Uuid
  eventType      String       @map("event_type") @db.VarChar(64)
  sequenceNo     BigInt       @map("sequence_no")
  payload        Json
  correlationId  String?      @map("correlation_id") @db.VarChar(64)
  status         OutboxStatus @default(PENDING)
  attempts       Int          @default(0)
  nextAttemptAt  DateTime?    @map("next_attempt_at") @db.Timestamptz(6)
  lastError      String?      @map("last_error")
  availableAt    DateTime     @default(now()) @map("available_at") @db.Timestamptz(6)
  publishedAt    DateTime?    @map("published_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([aggregateType, aggregateId, eventType, sequenceNo], name: "uq_outbox_dedupe")
  @@index([availableAt])
  @@index([aggregateType, aggregateId, sequenceNo])
  @@map("outbox_events")
}

model Notification {
  id                  String               @id @default(uuid()) @db.Uuid
  identityId          String               @map("identity_id") @db.Uuid
  channel             NotificationChannel
  category            NotificationCategory
  title               String               @db.VarChar(255)
  body                String
  data                Json?
  relatedResourceType String?              @map("related_resource_type") @db.VarChar(32)
  relatedResourceId   String?              @map("related_resource_id") @db.Uuid
  status              NotificationStatus   @default(PENDING)
  attempts            Int                  @default(0)
  lastError           String?              @map("last_error")
  scheduledFor        DateTime?            @map("scheduled_for") @db.Timestamptz(6)
  sentAt              DateTime?            @map("sent_at") @db.Timestamptz(6)
  deliveredAt         DateTime?            @map("delivered_at") @db.Timestamptz(6)
  readAt              DateTime?            @map("read_at") @db.Timestamptz(6)
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  identity Identity @relation(fields: [identityId], references: [id])

  @@index([identityId, createdAt(sort: Desc)])
  @@index([status, createdAt])
  @@index([relatedResourceType, relatedResourceId])
  @@map("notifications")
}

model DeviceToken {
  id         String         @id @default(uuid()) @db.Uuid
  identityId String         @map("identity_id") @db.Uuid
  token      String         @unique
  platform   DevicePlatform
  appVariant AppVariant     @map("app_variant")
  deviceId   String?        @map("device_id") @db.VarChar(128)
  appVersion String?        @map("app_version") @db.VarChar(32)
  osVersion  String?        @map("os_version") @db.VarChar(32)
  isActive   Boolean        @default(true) @map("is_active")
  lastUsedAt DateTime       @default(now()) @map("last_used_at") @db.Timestamptz(6)
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  identity Identity @relation(fields: [identityId], references: [id])

  @@index([identityId, isActive])
  @@map("device_tokens")
}

model AppSetting {
  id          String         @id @default(uuid()) @db.Uuid
  key         String         @db.VarChar(128)
  partnerId   String?        @map("partner_id") @db.Uuid
  value       Json
  valueType   AppSettingType @map("value_type")
  description String?
  isSecret    Boolean        @default(false) @map("is_secret")
  updatedBy   String?        @map("updated_by") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  partner Partner? @relation(fields: [partnerId], references: [id])

  @@map("app_settings")
}

// Simple join table backing /customers/me/favourites (Part 3.3 §12).
model CustomerFavourite {
  identityId String   @map("identity_id") @db.Uuid
  venueId    String   @map("venue_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  identity Identity @relation(fields: [identityId], references: [id])
  venue    Venue    @relation(fields: [venueId], references: [id])

  @@id([identityId, venueId])
  @@index([identityId, createdAt(sort: Desc)])
  @@index([venueId])
  @@map("customer_favourites")
}

// Forensic log of every inbound webhook. Idempotency defence is (provider, event_id) unique.
model WebhookReceipt {
  id          String    @id @default(uuid()) @db.Uuid
  provider    String    @db.VarChar(32)
  eventId     String    @map("event_id") @db.VarChar(128)
  eventType   String    @map("event_type") @db.VarChar(64)
  rawBody     Json      @map("raw_body")
  signature   String?   @db.VarChar(255)
  status      String    @default("RECEIVED") @db.VarChar(32)
  error       String?
  processedAt DateTime? @map("processed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([provider, eventId], map: "uq_webhook_event_id")
  @@index([status, createdAt])
  @@map("webhook_receipts")
}

model BackgroundJob {
  id            String              @id @default(uuid()) @db.Uuid
  jobName       String              @unique @map("job_name") @db.VarChar(64)
  jobType       BackgroundJobType   @map("job_type")
  scheduleCron  String?             @map("schedule_cron") @db.VarChar(64)
  status        BackgroundJobStatus @default(IDLE)
  lockedBy      String?             @map("locked_by") @db.VarChar(128)
  lockedUntil   DateTime?           @map("locked_until") @db.Timestamptz(6)
  lastRunAt     DateTime?           @map("last_run_at") @db.Timestamptz(6)
  lastSuccessAt DateTime?           @map("last_success_at") @db.Timestamptz(6)
  lastFailureAt DateTime?           @map("last_failure_at") @db.Timestamptz(6)
  lastError     String?             @map("last_error")
  nextRunAt     DateTime?           @map("next_run_at") @db.Timestamptz(6)
  runCount      Int                 @default(0) @map("run_count")
  failureCount  Int                 @default(0) @map("failure_count")
  payload       Json?
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([nextRunAt, status])
  @@map("background_jobs")
}
