rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    function isTurfAdmin(turfId) {
      return isAdmin() &&
             getUserData().managedTurfId == turfId;
    }

    // ── Users Collection ────────────────────────────────────────────────────
    match /users/{uid} {
      // Users can read and write only their own document
      allow read, write: if isOwner(uid);
    }

    // ── Turfs Collection ────────────────────────────────────────────────────
    match /turfs/{turfId} {
      // Anyone can read turf info (public listing)
      allow read: if true;

      // Only the turf's admin can update their own turf
      allow update: if isTurfAdmin(turfId);

      // Only super admin can create/delete turfs (handled via Admin SDK)
      allow create, delete: if false;

      // ── Slots Sub-collection ──────────────────────────────────────────────
      match /slots/{slotId} {
        // Anyone authenticated can read slot availability
        allow read: if isAuthenticated();

        // Authenticated users can update slots only within a transaction
        // (booking flow — slot status changes)
        allow update: if isAuthenticated() &&
          (
            // User booking: status available → booked
            (resource.data.status == 'available' &&
             request.resource.data.status == 'booked') ||
            // User cancelling: status booked → available
            (resource.data.status == 'booked' &&
             request.resource.data.status == 'available' &&
             resource.data.bookingId != null) ||
            // Admin blocking/unblocking
            isTurfAdmin(turfId)
          );

        // Only admin can create new slot docs (via seed or admin UI)
        allow create: if isTurfAdmin(turfId);
        allow delete: if isTurfAdmin(turfId);
      }
    }

    // ── Bookings Collection ─────────────────────────────────────────────────
    match /bookings/{bookingId} {
      // Users can read their own bookings; admins can read their turf's bookings
      allow read: if isAuthenticated() &&
        (request.auth.uid == resource.data.userId ||
         isTurfAdmin(resource.data.turfId));

      // Authenticated users can create bookings (enforced by transaction in app)
      allow create: if isAuthenticated();

      // Only the turf admin or booking user can update (cancel)
      allow update: if isAuthenticated() &&
        (request.auth.uid == resource.data.userId ||
         isTurfAdmin(resource.data.turfId));

      // No deletion allowed (preserve audit trail)
      allow delete: if false;
    }

    // ── Reviews Collection ──────────────────────────────────────────────────
    match /reviews/{reviewId} {
      // Public read
      allow read: if true;

      // Authenticated users can create reviews
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;

      // Users can edit/delete only their own reviews
      allow update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }
  }
}
